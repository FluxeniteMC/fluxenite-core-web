rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check by email — no UID dependency
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email == "bdgamer9191@gmail.com";
    }

    // Role-based admin check (for users promoted via the app)
    function isAdminRole() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isAdminEmail() || isAdminRole();
    }

    // Editor or admin by role or email
    function isAuthorized() {
      return request.auth != null && (
        isAdminEmail() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["editor", "admin"]
      );
    }

    // Users collection
    match /users/{uid} {
      allow read, write: if isAdmin();
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Blogs — public read; authorized write
    match /blogs/{id} {
      allow read: if true;
      allow create, update, delete: if isAuthorized();
    }

    // News — public read; authorized write
    match /news/{id} {
      allow read: if true;
      allow create, update, delete: if isAuthorized();
    }

    // Contacts — anyone can write; only admin reads
    match /contacts/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Subscribers — anyone can write their own; only admin reads
    match /subscribers/{email} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
